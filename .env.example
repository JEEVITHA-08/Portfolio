# Copy this file to .env and fill in real values. Never commit the real .env file.
# The site works fine with the form in "simulated send" mode if these are left blank.

# Web3Forms (https://web3forms.com) — simplest option, no backend required.
VITE_WEB3FORMS_ACCESS_KEY=

# EmailJS (https://www.emailjs.com) — alternative provider.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
